<ui:FAAppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:FluentAvalonia.UI.Windowing"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="RandCaller_Cross.MainWindow"
        Title="RandCaller Cross"
        Background="Transparent"
        TransparencyBackgroundFallback="#F3F3F3"
        TransparencyLevelHint="Mica"
        FontFamily="Segoe UI Variable">
    <Grid RowDefinitions="48,*">
        <!-- Title Bar -->
        <Grid Grid.Row="0"
              x:Name="TitleBarHost"
              Background="Transparent"
              PointerPressed="TitleBarHost_PointerPressed">
            <TextBlock Text="RandCaller"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontSize="12"
                       Opacity="0.8" />
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <TextBlock Text="Welcome to Avalonia!"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</ui:FAAppWindow>
